# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://learn_user:your_password@localhost:5432/learn"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# Google OAuth — from Google Cloud Console
# Authorised redirect URI: https://learn.wambugumartin.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://learn.wambugumartin.com"
PORT=3006

# ─── TTS Worker ───────────────────────────────────────────────────────────────
# Absolute path where generated audio MP3s are stored
AUDIO_DIR="/var/www/learn/public/audio/books"

# Max books to process per nightly TTS run
TTS_MAX_PER_RUN=10

# Path to Python with Kokoro installed (venv on server)
KOKORO_PYTHON="/home/admin/kokoro-venv/bin/python3"

# ─── Lesson Generator ─────────────────────────────────────────────────────────
# Ollama endpoint (already running on the Hetzner server)
OLLAMA_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Max new lessons generated per unit per nightly run
LESSON_GEN_MAX_PER_UNIT=5
