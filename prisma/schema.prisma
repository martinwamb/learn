generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required models ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  progress      UserProgress[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User profile & progress ─────────────────────────────────────────────────

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gradeCode   String   @default("G1") // PP1, PP2, G1, G2, G3
  avatar      String   @default("default")
  streak      Int      @default(0)
  totalPoints Int      @default(0)
  lastActive  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String?
  lesson      Lesson?   @relation(fields: [lessonId], references: [id])
  bookId      String?
  book        Book?     @relation(fields: [bookId], references: [id])
  type        String    // "lesson" | "book"
  completed   Boolean   @default(false)
  score       Int?
  timeSpent   Int?      // seconds
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, lessonId])
  @@unique([userId, bookId])
}

// ─── CBC Curriculum ──────────────────────────────────────────────────────────

model Grade {
  id       String    @id @default(cuid())
  code     String    @unique // PP1, PP2, G1, G2, G3
  name     String    // "Pre-Primary 1", "Grade 1"
  ageRange String    // "4-5", "6-7"
  order    Int       // for sorting
  subjects Subject[]
}

model Subject {
  id      String  @id @default(cuid())
  gradeId String
  grade   Grade   @relation(fields: [gradeId], references: [id])
  name    String
  slug    String
  icon    String  // emoji
  color   String  @default("#4F46E5") // hex color for UI
  units   Unit[]

  @@unique([gradeId, slug])
}

model Unit {
  id                 String   @id @default(cuid())
  subjectId          String
  subject            Subject  @relation(fields: [subjectId], references: [id])
  sequence           Int
  title              String
  outcomes           String[] // CBC learning outcomes
  targetLessonCount  Int      @default(10)
  lessons            Lesson[]

  @@unique([subjectId, sequence])
}

model Lesson {
  id         String         @id @default(cuid())
  unitId     String
  unit       Unit           @relation(fields: [unitId], references: [id])
  sequence   Int
  title      String
  objective  String
  content    Json           // array of content blocks
  activities Json           // array of activity items
  funFact    String?
  duration   Int            @default(20) // minutes
  source     String         @default("seed") // "seed" | "ai-generated"
  status     String         @default("published") // "published" | "draft"
  progress   UserProgress[]
  createdAt  DateTime       @default(now())

  @@unique([unitId, sequence])
}

// ─── Book library ────────────────────────────────────────────────────────────

model Book {
  id          String         @id @default(cuid())
  externalId  String
  source      String         // "open-library" | "gutenberg" | "african-storybook" | "storyweaver"
  title       String
  author      String?
  coverUrl    String?
  contentUrl  String?
  language    String         @default("en")
  ageMin      Int            @default(4)
  ageMax      Int            @default(9)
  text        String?        @db.Text // cached full text for TTS
  audioStatus String         @default("pending") // "pending" | "processing" | "ready" | "failed"
  audioPath   String?        // served path e.g. /audio/books/{id}.mp3
  segmentPlan Json?          // parsed narration/dialogue segments with voice assignments
  progress    UserProgress[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([source, externalId])
}

// ─── Background worker logs ──────────────────────────────────────────────────

model GeneratorLog {
  id              String   @id @default(cuid())
  workerType      String   // "tts" | "lesson"
  ranAt           DateTime @default(now())
  unitsProcessed  Int      @default(0)
  lessonsCreated  Int      @default(0)
  booksProcessed  Int      @default(0)
  errors          String[] @default([])
  durationMs      Int      @default(0)
}
